{
    "compilerOptions": {
        "strictPropertyInitialization": false,
        "allowSyntheticDefaultImports": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ESNext",
        "jsx": "react-jsx",
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": true,
        "sourceMap": true,
        "skipLibCheck": true
    },
    "lib": [
        "es5",
        "dom",
        "es2015.collection",
        "es2015.promise",
        "ES2015",
        "ES2016",
        "ES2017",
        "ES2020"
    ],
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}